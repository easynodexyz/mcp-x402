{
  "name": "@easynodexyz/mcp-x402",
  "version": "0.0.1",
  "description": "MCP server for AI agents to purchase VPS/Node products via Easy Node's x402 API with USDC on Base",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "mcp-x402": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/index.js', '755')\"",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:check": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run build",
    "release": "npm run build && changeset publish",
    "docs:dev": "cd docs && mintlify dev",
    "docs:build": "cd docs && mintlify build"
  },
  "keywords": [
    "easy-node",
    "mcp",
    "mcp-server",
    "x402",
    "base",
    "blockchain-transactions",
    "rent-vps",
    "rent-blockchain-nodes",
    "ai-agents",
    "claude-code-plugin",
    "model-context-protocol"
  ],
  "author": "Easy Node <contact@easy-node.xyz>",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/easynodexyz/mcp-x402.git"
  },
  "bugs": {
    "url": "https://github.com/easynodexyz/mcp-x402/issues"
  },
  "homepage": "https://easy-node.xyz",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.25.3",
    "@noble/ciphers": "2.1.1",
    "@noble/secp256k1": "3.0.0",
    "commander": "14.0.2",
    "dotenv": "17.2.3",
    "viem": "2.45.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.8",
    "@types/node": "25.1.0",
    "@typescript-eslint/eslint-plugin": "8.54.0",
    "@typescript-eslint/parser": "8.54.0",
    "eslint": "9.39.2",
    "eslint-plugin-prettier": "5.5.5",
    "mintlify": "4.2.307",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
