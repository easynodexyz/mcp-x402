{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.easynodexyz/mcp-x402",
  "title": "Easy Node x402",
  "description": "MCP server for AI agents to purchase VPS/Node products via Easy Node's x402 API with USDC on Base",
  "repository": {
    "url": "https://github.com/easynodexyz/mcp-x402",
    "source": "github"
  },
  "websiteUrl": "https://easy-node.xyz",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/easynodexyz/mcp-x402/main/mcpb/icon.png",
      "mimeType": "image/png"
    }
  ],
  "version": "0.0.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@easynodexyz/mcp-x402",
      "version": "0.0.2",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        {
          "name": "EASYNODE_PRIVATE_KEY",
          "description": "Wallet private key (0x-prefixed)",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "EASYNODE_API_URL",
          "description": "API base URL",
          "isRequired": false,
          "isSecret": false
        },
        {
          "name": "EASYNODE_MAX_PAYMENT",
          "description": "Max USDC per tx",
          "isRequired": false,
          "isSecret": false
        }
      ]
    }
  ]
}
